# ============================================================================
# Método Revisão — Environment Variables
# Copy this file to .env.local and fill in real values before running.
# NEVER commit .env.local to version control.
# ============================================================================

# ─── Site URL (REQUIRED — must match your deployment domain) ─────────────────
# Used for: email confirmation links, password-reset links, signout redirect.
# Development:  http://localhost:3000
# Production:   https://yourdomain.com   ← update before deploying!
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use whichever key name your Supabase project exposes (newer projects use the
# PUBLISHABLE_DEFAULT_KEY name; older projects use ANON_KEY — both work):
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# ─── Supabase Auth — Redirect URLs (configure in Dashboard) ──────────────────
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL:      <your NEXT_PUBLIC_SITE_URL>
#   Redirect URLs: <your NEXT_PUBLIC_SITE_URL>/auth/callback
#
# These are not env vars — they must be set directly in the Supabase Dashboard.

# ─── Supabase Storage — essay-images bucket (manual setup required) ──────────
# See supabase/schema.sql for full instructions.
# Before deploying: create the 'essay-images' bucket in the Supabase Dashboard
# (Storage → New bucket → Public: YES → Max size: 8 MB).
# Then run the storage RLS policies from schema.sql in the SQL Editor.
